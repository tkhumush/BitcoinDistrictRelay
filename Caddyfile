# Caddy configuration for Bitcoin District
# Apex domain bitcoindistrict.org is served elsewhere (not on this server).
# We only handle relay.* and cherry.* subdomains.

# Nostr relay - WebSocket support
relay.bitcoindistrict.org {
    # Reverse proxy to strfry relay
    reverse_proxy nostr-relay:7777 {
        # WebSocket support
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
    }

    # Logging
    log {
        output stdout
        format console
    }
}

# Blossom media server - large file uploads
cherry.bitcoindistrict.org {
    # Primal iOS sends t:"upload" auth for all uploads but hits PUT /media first.
    # /media requires t:"media" → 403. Rewrite to /upload so the auth verb matches.
    @media-put {
        method PUT
        path /media
    }
    rewrite @media-put /upload

    # Reverse proxy to blossom server
    reverse_proxy blossom-server:3000 {
        # Large file upload support
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}

        # Timeouts for large uploads
        transport http {
            read_timeout 600s
            write_timeout 600s
        }

        # blossom-server returns 201 Created for new uploads;
        # Primal iOS expects 200 OK (same as blossom.primal.net).
        @created status 201
        handle_response @created {
            copy_response_headers
            copy_response 200
        }
    }

    # Allow large file uploads (50MB)
    request_body {
        max_size 50MB
    }

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
    }

    # Logging
    log {
        output stdout
        format console
    }
}
