# Caddy configuration for Bitcoin District
# Automatic HTTPS enabled for all domains

# Main domain - serves static content + NIP-05
bitcoindistrict.org, www.bitcoindistrict.org {
    # Serve static files
    root * /usr/share/caddy
    file_server

    # NIP-05: /.well-known/nostr.json
    # Must serve with CORS and Content-Type for Nostr clients
    handle_path /.well-known/nostr.json {
        header Content-Type application/json
        header Access-Control-Allow-Origin *
        header Access-Control-Allow-Methods "GET, OPTIONS"
        header Cache-Control "public, max-age=3600"
        file_server {
            root /usr/share/caddy
        }
    }

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
    }

    # Logging
    log {
        output stdout
        format console
    }
}

# Nostr relay - WebSocket support
relay.bitcoindistrict.org {
    # Reverse proxy to strfry relay
    reverse_proxy nostr-relay:7777 {
        # WebSocket support
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
    }

    # Logging
    log {
        output stdout
        format console
    }
}

# Blossom media server - large file uploads
cherry.bitcoindistrict.org {
    # Reverse proxy to blossom server
    reverse_proxy blossom-server:3000 {
        # Large file upload support
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}

        # Timeouts for large uploads
        transport http {
            read_timeout 600s
            write_timeout 600s
        }
    }

    # Allow large file uploads (100MB)
    request_body {
        max_size 100MB
    }

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
    }

    # Logging
    log {
        output stdout
        format console
    }
}
